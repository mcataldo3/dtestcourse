<worksheet>
  <title>Shape and Color Composition</title>

  <!-- Optional introduction -->
  <introduction>
    <p>
    Creating abstract, shallow depth in a space using shape without traditional landscape perspective 
    </p>
    <p>Artist inspiration: James Jean</p> 
  </introduction>

