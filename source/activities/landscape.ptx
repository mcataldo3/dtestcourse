  <title>Imagined Landscape</title>

  <!-- Optional introduction -->
  <introduction>
    <p>
     Creating a landscape with believable depth using color, overlap, value, scale, and space
    </p>
    <p>Artist inspiration: James Jean, Renoir</p>
